# Скопируйте в .env и заполните.

# --- Telegram (или только Hub ниже) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USER_IDS=

# Уведомления: idle — одно короткое сообщение после стабилизации снимка (по умолчанию).
# legacy — как раньше: большой текст при каждом изменении DOM (не чаще MIN_NOTIFY_INTERVAL_MS).
# TELEGRAM_NOTIFY_MODE=idle

# Сколько миллисекунд подряд снимок должен быть неизменным, чтобы отправить Telegram (режим idle).
# TELEGRAM_STABLE_MS=16000

# Максимальная длина текста-саммари в Telegram (режим idle).
# TELEGRAM_SUMMARY_MAX_CHARS=1200

# Минимальный интервал между двумя Telegram-сообщениями в режиме idle (антидребезг между «завершениями»).
# MIN_NOTIFY_INTERVAL_MS=8000

# Кодовая фраза завершения (режим idle): если задана, «✅ Готово» уходит только когда эта строка есть
# в последних блоках снимка (по умолчанию проверяются до 8 блоков с конца — см. TELEGRAM_DONE_PHRASE_TAIL_BLOCKS).
# Пример: TELEGRAM_DONE_PHRASE=<<<CURSOR_RELAY_DONE>>>
# TELEGRAM_DONE_PHRASE=

# Сколько последних блоков снимка проверять на TELEGRAM_DONE_PHRASE (минимум 2, по умолчанию 8).
# TELEGRAM_DONE_PHRASE_TAIL_BLOCKS=8

# Опрос в Telegram, если в саммари распознаны 2–12 вариантов (нумерация, маркеры •-/ или строки с «?»).
# Голос отправляет выбранный текст в композер Cursor. Опрос неанонимный (для whitelist). 0/false/off — выкл.
# TELEGRAM_PLAN_POLL=1
# TELEGRAM_PLAN_POLL_DEFAULT_QUESTION=Уточните по плану

# POLL_INTERVAL_MS=4000

# TELEGRAM_API_ROOT=
# HTTP CONNECT-прокси для api.telegram.org (undici ProxyAgent). SOCKS сюда не подставлять.
# TELEGRAM_PROXY_URL=http://127.0.0.1:7890
# Временно не использовать прокси (например прокси мёртв → getMe/sendMessage failed), идти напрямую:
# TELEGRAM_PROXY_DISABLE=1

# --- Hub / портал ---
# HUB_URL=http://localhost:3000
# Опционально: публичный URL портала (туннель). Ingest relay → портал по HUB_URL.
# HUB_PUBLIC_URL=https://xxxx.loca.lt
# HUB_INGEST_SECRET=
# HUB_CONTROL_SECRET=

# AGENT_ID=cursor-agent
# AGENT_LABEL=Cursor Agent

CDP_URL=http://127.0.0.1:9222
# CURSOR_PAGE_TITLE_SUBSTRING=Cursor

# CONTINUE_PHRASE=Continue
# SEND_MODIFIERS=enter

# SNAPSHOT_MAX_CHARS=3500
# Запасные клавиши после встроенных шагов (Shift+Tab, клик Plan, палитра «Plan Mode»). Сегменты через |
# Пример: CURSOR_PLAN_MODE_KEYS=Shift+Tab
# CURSOR_PLAN_MODE_KEYS=

# Режим Agent: сначала выпадающее меню режима у композера (если есть), затем вкладка через Playwright/CSS, палитра (Switch to Agent, …), затем клавиши:
# CURSOR_AGENT_MODE_KEYS=

# Необязательно: CSS к кнопке/combobox, открывающему список режимов Agent / Plan / Ask / Debug (если авто-поиск триггера на вашей сборке Cursor промахивается).
# CURSOR_COMPOSER_MODE_TRIGGER_SELECTOR=

# Выполнение плана Build из Telegram (inline «Выполнить план», если итог похож на план): по умолчанию Control+Enter после фокуса композера
# CURSOR_PLAN_BUILD_KEYS=
# AGENT_CONTROL_PORT=4000
# Для portal в K8s/Docker на хосте раскомментируйте (иначе только 127.0.0.1, host.docker.internal не подключится):
# AGENT_CONTROL_BIND=0.0.0.0
# Защита — Bearer HUB_CONTROL_SECRET. На публичной сети не включайте без файрвола.
