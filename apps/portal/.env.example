# Локальный agent-hub (страница /agent-hub)
HUB_PASSWORD=
HUB_SESSION_SECRET=
HUB_INGEST_SECRET=
HUB_CONTROL_SECRET=
HUB_OIDC_SIGNING_SECRET=
HUB_OIDC_ISSUER=alproject-portal
HUB_OIDC_AUDIENCE=agent-hub-miniapp
HUB_OIDC_TTL_SEC=900
HUB_TELEGRAM_MAX_AGE_SEC=300
HUB_TELEGRAM_ALLOWED_USER_IDS=
HUB_ALLOWED_ORIGIN=
# Пусто/false — cookie на http:// (localhost, Docker). В production по HTTPS можно true.
# HUB_COOKIE_SECURE=false

# Если задан — ingest и чтение снимка идут через отдельный сервис @alproject/agent-hub-gateway (см. docker-compose profile agent).
# Пример в Docker: http://agent-hub-gateway:3010
AGENT_HUB_BACKEND_URL=

# Куда портал проксирует control/history (локальный relay cursor-agent-telegram).
# Портал на хосте (npm run dev): 127.0.0.1. Портал в Docker, relay на хосте: host.docker.internal (см. docker-compose).
AGENT_CONTROL_URL=http://127.0.0.1:4000
# Опционально: JSON-мапа control URL по agentId (приоритетнее AGENT_CONTROL_URL).
# AGENT_CONTROL_URLS_JSON={"agent-main":"http://127.0.0.1:4000","agent-review":"http://127.0.0.1:4001"}
