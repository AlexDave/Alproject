# Скопируйте в файл `.env` в корне репозитория (рядом с docker-compose.yml).
# Compose подставит переменные в контейнер portal / agent-hub-gateway.

# Совпадает с HUB_CONTROL_SECRET в projects/js/cursor-agent-telegram/.env (обязателен для HTTP relay).
HUB_CONTROL_SECRET=

# Совпадает с HUB_INGEST_SECRET там же и в relay (ингест в портал / gateway).
HUB_INGEST_SECRET=

HUB_SESSION_SECRET=
HUB_PASSWORD=
HUB_OIDC_SIGNING_SECRET=

# Портал в Docker → relay на хосте Windows/macOS Docker Desktop:
AGENT_CONTROL_URL=http://host.docker.internal:4000

# На relay в .env при этом же сценарии добавьте: AGENT_CONTROL_BIND=0.0.0.0

# HTTP без TLS (локально / Docker): обязательно, иначе cookie Agent Hub не работают и SSE даёт 401
HUB_COOKIE_SECURE=false
